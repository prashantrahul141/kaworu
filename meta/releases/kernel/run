ISO_PATH=kaworu.iso
EFI_FIRMWARE=. # Point to efi firmware for qemu

qemu-system-aarch64 -M virt -cpu cortex-a72 \
			-m 2G \
			-device ramfb \
			-device qemu-xhci \
			-device usb-kbd \
			-device usb-tablet \
			-drive if=pflash,unit=0,format=raw,file="$EFI_FIRMWARE",readonly=on \
			-cdrom "$ISO_PATH"
