
#
# General Setup
#
CONFIG_PER_CPU_STACK_SIZE=16384
CONFIG_BOOT_STACK_SIZE=16384
# end of General Setup

#
# Building
#
CONFIG_OPTIMIZATIONS_NONE=y
# CONFIG_OPTIMIZATIONS_LOW is not set
# CONFIG_OPTIMIZATIONS_MEDIUM is not set
# CONFIG_OPTIMIZATIONS_HIGH is not set
# end of Building

#
# Drivers
#
CONFIG_MAX_ACTIVE_DEVICES_COUNT=256
# end of Drivers

#
# Running via qemu
#
CONFIG_CPU_COUNT=1
CONFIG_PHYSICAL_MEMORY_MB=128
# end of Running via qemu

#
# Hacking
#
CONFIG_DEBUG_CHECKS=y
CONFIG_DEBUG_SYMBOLS=y
# CONFIG_LOGGING_LEVEL_TRACE is not set
CONFIG_LOGGING_LEVEL_DEBUG=y
# CONFIG_LOGGING_LEVEL_INFO is not set
# CONFIG_LOGGING_LEVEL_WARN is not set
# CONFIG_LOGGING_LEVEL_ERROR is not set
# end of Hacking
